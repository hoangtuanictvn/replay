{
  "name": "@relay/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./svm": {
      "types": "./dist/svm/index.d.ts",
      "import": "./dist/svm/index.js"
    },
    "./cloner": {
      "types": "./dist/cloner/index.d.ts",
      "import": "./dist/cloner/index.js"
    }
