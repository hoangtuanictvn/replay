{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./out-tsc/node",
    "rootDir": ".",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "types": ["node", "electron"],
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "incremental": false,
    "verbatimModuleSyntax": false
  },
  "include": ["src/main/**/*", "src/preload/**/*", "src/worker/**/*", "electron.vite.config.ts"]
}
