{
  "name": "relay",
  "version": "0.0.0",
  "private": true,
  "description": "Solana program cloner + LiteSVM sandbox with simulation, replay, trace, and diff",
  "license": "SEE LICENSE IN LICENSE",
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf dist out .tsbuildinfo",
    "cli": "pnpm --filter @relay/core-cli start"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.0"
  }
}
